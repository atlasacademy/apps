  "devDependencies": {
    "@types/chai": "^4.2.18",
    "@types/mocha": "^8.2.2",
    "@types/uuid": "^8.3.0",
    "chai": "^4.3.4",
    "mocha": "^8.4.0",
    "ts-node": "^9.1.1",
    "typescript": "^4.1.3"
  },
  "dependencies": {
    "@atlasacademy/api-connector": "^3.0.29"
  },
  "publishConfig": {
    "access": "public"
  }
