{
    "name": "@atlasacademy/battle",
    "type": "module",
    "version": "0.6.0",
    "description": "Library to run fgo battle simulations",
    "homepage": "https://github.com/atlasacademy/apps/tree/master/packages/battle",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/esm/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "default": "./dist/esm/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "fetch-test-data": "node --loader ts-node/esm/transpile-only test-data/fetchTestData.ts",
        "test": "npm run fetch-test-data && node --loader ts-node/esm/transpile-only test-data/runTests.ts",
        "test-win": "npm run test",
        "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:cjs-package",
        "clean": "node ../../scripts/clean-package-dist.cjs",
        "build:esm": "tsc -p tsconfig.json",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:cjs-package": "node ../../scripts/write-cjs-package-json.cjs dist/cjs",
        "prepare": "npm run build",
        "link": "npm run build && npm link",
        "watch": "tsc -p tsconfig.json --watch --preserveWatchOutput"
    },
    "license": "ISC",
    "devDependencies": {
        "@types/chai": "^4.2.18",
        "@types/glob": "^7.1.3",
        "@types/mocha": "^8.2.2",
        "@types/node": "^15.6.1",
        "@types/tar": "^4.0.4",
        "@types/uuid": "^8.3.0",
        "axios": "^0.21.1",
        "chai": "^4.3.4",
        "glob": "^7.1.6",
        "mocha": "^8.4.0",
        "tar": "^6.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@atlasacademy/api-connector": "^6.0.0"
    },
    "prettier": {
        "tabWidth": 4,
        "printWidth": 120,
        "importOrder": [
            "<THIRD_PARTY_MODULES>",
            "^@atlasacademy/(.*)$",
            "^[./].*(?<!css)$",
            "(.*).css$",
            "^[./]"
        ],
        "importOrderSeparation": true,
        "importOrderParserPlugins": [
            "typescript"
        ]
    },
    "publishConfig": {
        "access": "public"
    }
}
