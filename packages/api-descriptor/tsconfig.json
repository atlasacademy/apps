{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ES2020",
        "lib": ["ESNext", "DOM"],
        "declaration": true,
        "declarationMap": true,
        "moduleResolution": "NodeNext",
        "rootDir": "./src",
        "outDir": "./dist/esm",
        "strict": true,
        "resolveJsonModule": true,
        "esModuleInterop": true
    },
    "include": ["src/**/*"]
}
